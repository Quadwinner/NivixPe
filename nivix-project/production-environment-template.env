# Production Environment Variables Template
# Copy this file to .env and fill in the actual production values

# ============================================================================
# ENVIRONMENT
# ============================================================================
NODE_ENV=production

# ============================================================================
# SOLANA BLOCKCHAIN CONFIGURATION
# ============================================================================
# CRITICAL: Use mainnet-beta for production, devnet for testing only
SOLANA_RPC_ENDPOINT=https://api.mainnet-beta.solana.com

# Alternative RPC endpoints (choose based on your needs):
# SOLANA_RPC_ENDPOINT=https://solana-api.projectserum.com
# SOLANA_RPC_ENDPOINT=https://rpc.ankr.com/solana

# ============================================================================
# PAYMENT GATEWAY CONFIGURATION (RAZORPAY)
# ============================================================================
# Get these from your Razorpay dashboard
RAZORPAY_KEY_ID=rzp_live_YOUR_LIVE_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_LIVE_KEY_SECRET
RAZORPAY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# ============================================================================
# EXCHANGE RATE SERVICE
# ============================================================================
# Get API key from your exchange rate provider
EXCHANGE_RATE_API_KEY=YOUR_EXCHANGE_RATE_API_KEY
EXCHANGE_RATE_PRIMARY_API=https://api.exchangerate-api.com/v4/latest/
EXCHANGE_RATE_SECONDARY_API=https://api.fixer.io/latest
EXCHANGE_RATE_CACHE_TTL=300
EXCHANGE_RATE_STALE_THRESHOLD=600
EXCHANGE_RATE_TIMEOUT=5000

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_HOST=your-production-db-host.com
DB_PORT=5432
DB_NAME=nivix_production
DB_USER=your_db_user
DB_PASSWORD=your_secure_db_password

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
JWT_SECRET=your_super_secure_jwt_secret_here
API_SECRET_KEY=your_api_secret_key_here
ENCRYPTION_KEY=your_encryption_key_here

# ============================================================================
# SERVICE CONFIGURATION
# ============================================================================
PORT=3002
CORS_ORIGIN=https://yourdomain.com
API_RATE_LIMIT=100

# ============================================================================
# LOGGING AND MONITORING
# ============================================================================
LOG_LEVEL=info
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================================================
# BRIDGE SERVICE CONFIGURATION
# ============================================================================
REACT_APP_BRIDGE_URL=https://api.yourdomain.com

# ============================================================================
# COMPLIANCE AND KYC
# ============================================================================
KYC_PROVIDER_API_KEY=your_kyc_provider_api_key
SANCTIONS_SCREENING_API_KEY=your_sanctions_api_key

# ============================================================================
# TREASURY MANAGEMENT
# ============================================================================
# These are automatically loaded from configuration files
# Ensure the following files exist with production data:
# - data/treasury-token-mints.json
# - data/treasury-keypair.json
# - data/treasury-config.json

# ============================================================================
# OPERATIONAL SETTINGS
# ============================================================================
MAX_CONCURRENT_TRANSACTIONS=100
TRANSACTION_TIMEOUT=30000
RETRY_ATTEMPTS=3
HEALTH_CHECK_INTERVAL=30000