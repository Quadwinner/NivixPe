# Copy values into .env on the host that runs bridge-service (e.g. EC2 behind VPC endpoint to AMB).
#
# AWS tutorial (create network, endpoint, peer, client, enroll, channel, chaincode):
# https://docs.aws.amazon.com/managed-blockchain/latest/hyperledger-fabric-dev/managed-blockchain-get-started-tutorial.html
#
# After enrollment, place the Fabric connection profile JSON and the file-system wallet on this server.
# Chaincode name and channel must match what you committed on AMB (defaults match local nivix-kyc / mychannel).

# local-cli = Docker test-network + fabric-invoke.sh (default)
# gateway   = fabric-network Gateway (use for Amazon Managed Blockchain)
FABRIC_MODE=local-cli

# --- gateway / AMB (set FABRIC_MODE=gateway) ---
# FABRIC_CONNECTION_PROFILE_PATH=/opt/nivix/fabric/connection-profile.json
# FABRIC_WALLET_PATH=/opt/nivix/fabric/wallet
# FABRIC_WALLET_USER=appUser
# FABRIC_CHANNEL=mychannel
# FABRIC_CHAINCODE=nivix-kyc
# AMB / remote peers: false. Local discovery quirks: try true only if AWS docs say so.
# FABRIC_DISCOVERY_AS_LOCALHOST=false

# --- local CLI ---
# FABRIC_INVOKE_SCRIPT=/tmp/fabric-invoke.sh
# NIVIX_PROJECT_ROOT=/path/to/nivix-project
