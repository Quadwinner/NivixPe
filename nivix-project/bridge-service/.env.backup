# Nivix Staging Environment Configuration
# For E2E testing with Devnet + Razorpay Test APIs

# Environment
NODE_ENV=staging
PORT=3002

# Solana Configuration (Devnet)
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com/

# USDC Configuration (Devnet)
USDC_MINT_ADDRESS=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Treasury Configuration
TREASURY_MIN_BALANCE_SOL=0.1
TREASURY_ALERT_THRESHOLD=0.05

# Razorpay Configuration (Test Mode)
RAZORPAY_ENV=test
RAZORPAY_KEY_ID=rzp_test_RIdBFJTZ7hhBQv
RAZORPAY_KEY_SECRET=xC9cfe4eq1OmVrjcWe4WTVt6

# Banking Integration (Test Mode)
ENABLE_UPI_PAYOUTS=true
ENABLE_ACH_PAYOUTS=false
ENABLE_SEPA_PAYOUTS=false

# Security Settings (Relaxed for testing)
ENABLE_RATE_LIMITING=false
ENABLE_TRANSACTION_MONITORING=true
ENABLE_COMPLIANCE_CHECKS=false
MAX_TRANSACTION_AMOUNT=100000

# Logging
LOG_LEVEL=debug
ENABLE_METRICS=true

# CORS Settings
ALLOWED_ORIGINS=*

# Feature Flags
ENABLE_OFFRAMP=true
ENABLE_TREASURY_MANAGEMENT=true
ENABLE_STABLECOIN_BRIDGE=true

# Test Configuration
TEST_MODE=true
SKIP_REAL_BANKING=false
SIMULATE_WEBHOOKS=true
